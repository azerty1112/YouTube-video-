    "#@title 🎬 تثبيت FFmpeg وأدوات النظام\n",
    "\n",
    "import subprocess\n",
    "import shutil\n",
    "\n",
    "def check_and_install_ffmpeg():\n",
    "    \"\"\"التحقق من تثبيت FFmpeg وتثبيته إذا لزم الأمر\"\"\"\n",
    "    try:\n",
    "        result = subprocess.run(['ffmpeg', '-version'], capture_output=True, check=True)\n",
    "        print(\"✓ FFmpeg متاح بالفعل\")\n",
    "        return True\n",
    "    except (subprocess.CalledProcessError, FileNotFoundError):\n",
    "        print(\"⚠ FFmpeg غير متاح، جاري التثبيت...\")\n",
    "        try:\n",
    "            subprocess.run(['apt-get', 'update'], check=True, capture_output=True)\n",
    "            subprocess.run(\n",
    "                ['apt-get', 'install', '-y', 'ffmpeg'],\n",
    "                check=True,\n",
    "                capture_output=True\n",
    "            )\n",
    "            print(\"✓ تم تثبيت FFmpeg بنجاح\")\n",
    "            return True\n",
    "        except Exception as e:\n",
    "            print(f\"✗ فشل تثبيت FFmpeg: {e}\")\n",
    "            return False\n",
    "\n",
    "def check_and_install_imagemagick():\n",
    "    \"\"\"تثبيت ImageMagick لمعالجة الصور\"\"\"\n",
    "    try:\n",
    "        subprocess.run(\n",
    "            ['apt-get', 'install', '-y', 'imagemagick'],\n",
    "            check=True,\n",
    "            capture_output=True\n",
    "        )\n",
    "        print(\"✓ تم تثبيت ImageMagick\")\n",
    "        return True\n",
    "    except Exception as e:\n",
    "        print(f\"⚠ لم يتمكن من تثبيت ImageMagick: {e}\")\n",
    "        return False\n",
    "\n",
    "print(\"🔧 تثبيت أدوات النظام المطلوبة...\\n\")\n",
    "\n",
    "ffmpeg_ok = check_and_install_ffmpeg()\n",
    "imagemagick_ok = check_and_install_imagemagick()\n",
    "\n",
    "if ffmpeg_ok:\n",
    "    print(\"\\n✅ اكتملت تثبيت جميع أدوات النظام\")\n",
    "else:\n",
    "    print(\"\\n⚠️ تحذير: بعض الأدوات قد لا تعمل بشكل صحيح\")"
   ]
