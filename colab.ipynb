    "#@title 🌐 إنشاء واجهة Gradio\n",
    "\n",
    "class GradioInterface:\n",
    "    \"\"\"واجهة Gradio للتطبيق\"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        \"\"\"تهيئة الواجهة\"\"\"\n",
    "        self.generator = None\n",
    "    \n",
    "    def initialize(self, github_token: str = \"\"):\n",
    "        \"\"\"تهيئة المولد\"\"\"\n",
    "        try:\n",
    "            self.generator = YouTubeShortsGenerator(github_token if github_token else None)\n",
    "            return \"✅ تم تهيئة التطبيق بنجاح!\"\n",
    "        except Exception as e:\n",
    "            return f\"❌ فشل تهيئة التطبيق: {e}\"\n",
    "    \n",
    "    def process_title(\n",
    "        self,\n",
    "        title: str,\n",
    "        upload_to_github: bool = False,\n",
    "        color_r: int = 20,\n",
    "        color_g: int = 25,\n",
    "        color_b: int = 50\n",
    "    ) -> Tuple[str, str, str]:\n",
    "        \"\"\"\n",
    "        معالجة طلب إنشاء فيديو\n",
    "        \n",
    "        Args:\n",
    "            title: عنوان الفيديو\n",
    "            upload_to_github: التحميل إلى GitHub\n",
    "            color_r, color_g, color_b: ألوان الخلفية\n",
    "            \n",
    "        Returns:\n",
    "            tuple: (الحالة، مسار الفيديو، السيناريو)\n",
    "        \"\"\"\n",
    "        if not self.generator:\n",
    "            return \"❌ التطبيق غير مهيأ\", \"\", \"\"\n",
    "        \n",
    "        # التحقق من الإدخال\n",
    "        if not title or len(title.strip()) < 3:\n",
    "            return \"❌ الرجاء إدخال عنوان صحيح (3 أحرف على الأقل)\", \"\", \"\"\n",
    "        \n",
    "        try:\n",
    "            success, video_path, data = self.generator.generate_short(\n",
    "                title,\n",
    "                upload_to_github,\n",
    "                background_color=(color_r, color_g, color_b)\n",
    "            )\n",
    "            \n",
    "            if success:\n",
    "                status_msg = f\"\"\"\n",
    "✅ تم إنشاء الفيديو بنجاح!\n",
    "\n",
    "📊 تفاصيل:\n",
    "━━━━━━━━━━━━━━━━━━━━━━\n",
    "📝 العنوان: {data.get('title', '')}\n",
    "📍 المسار: {video_path}\n",
    "📦 حجم الملف: {data.get('file_size', 0):.2f} MB\n",
    "⏱️ الوقت: {data.get('timestamp', '')}\n",
    "🎨 الخلفية: RGB({color_r}, {color_g}, {color_b})\n",
    "                \"\"\"\n",
    "                return status_msg, video_path, data.get('scenario', '')\n",
    "            else:\n",
    "                return f\"❌ فشل الإنشاء: {data.get('error', 'خطأ غير معروف')}\", \"\", \"\"\n",
    "                \n",
    "        except Exception as e:\n",
    "            return f\"❌ خطأ: {str(e)}\", \"\", \"\"\n",
    "    \n",
    "    def create_interface(self):\n",
    "        \"\"\"إنشاء واجهة Gradio المتقدمة\"\"\"\n",
    "        import gradio as gr\n",
    "        \n",
    "        # تهيئة المولد\n",
