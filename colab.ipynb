    "#@title 🔊 فئة تحويل النص إلى كلام\n",
    "\n",
    "class TextToSpeechEngine:\n",
    "    \"\"\"محرك تحويل النص إلى كلام\"\"\"\n",
    "    \n",
    "    def __init__(self, language: str = 'ar'):\n",
    "        \"\"\"\n",
    "        تهيئة محرك TTS\n",
    "        \n",
    "        Args:\n",
    "            language: اللغة ('ar' للعربية، 'en' للإنجليزية)\n",
    "        \"\"\"\n",
    "        self.language = language\n",
    "        self.engine = None\n",
    "        self._initialize_engine()\n",
    "    \n",
    "    def _initialize_engine(self):\n",
    "        \"\"\"تهيئة محرك pyttsx3\"\"\"\n",
    "        try:\n",
    "            import pyttsx3\n",
    "            self.engine = pyttsx3.init()\n",
    "            self.engine.setProperty('rate', 150)  # سرعة النطق\n",
    "            self.engine.setProperty('volume', 0.9)  # مستوى الصوت\n",
    "            print(\"✓ تم تهيئة محرك TTS بنجاح\")\n",
    "        except Exception as e:\n",
    "            print(f\"⚠ فشل تهيئة محرك TTS: {e}\")\n",
    "    \n",
    "    def text_to_speech(self, text: str, output_path: str) -> bool:\n",
    "        \"\"\"\n",
    "        تحويل النص إلى ملف صوتي\n",
    "        \n",
    "        Args:\n",
    "            text: النص المراد تحويله\n",
    "            output_path: مسار حفظ الملف الصوتي\n",
    "            \n",
    "        Returns:\n",
    "            True إذا نجحت العملية\n",
    "        \"\"\"\n",
    "        try:\n",
    "            if not self.engine:\n",
    "                print(\"⚠ محرك TTS غير متاح\")\n",
    "                return False\n",
    "            \n",
    "            # تقسيم النص إذا كان طويلاً جداً\n",
    "            if len(text) > 1000:\n",
    "                text = text[:1000]\n",
    "            \n",
    "            self.engine.save_to_file(text, output_path)\n",
    "            self.engine.runAndWait()\n",
    "            \n",
    "            if os.path.exists(output_path) and os.path.getsize(output_path) > 0:\n",
    "                print(f\"✓ تم إنشاء ملف صوتي: {output_path}\")\n",
    "                return True\n",
    "            else:\n",
    "                print(\"⚠ فشل إنشاء الملف الصوتي\")\n",
    "                return False\n",
    "                \n",
    "        except Exception as e:\n",
    "            print(f\"✗ خطأ في تحويل النص إلى كلام: {e}\")\n",
    "            return False\n",
    "\n",
    "print(\"✓ تم إنشاء فئة TextToSpeechEngine\")"
   ]
