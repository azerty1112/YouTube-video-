    "#@title 📤 فئة إدارة GitHub\n",
    "\n",
    "class GithubManager:\n",
    "    \"\"\"إدارة تحميل وحفظ الفيديوهات على GitHub\"\"\"\n",
    "    \n",
    "    def __init__(self, github_token: str = None, repo_name: str = \"youtube-shorts-generator\"):\n",
    "        \"\"\"\n",
    "        تهيئة مدير GitHub\n",
    "        \n",
    "        Args:\n",
    "            github_token: رمز GitHub (أو من متغيرات البيئة)\n",
    "            repo_name: اسم المستودع\n",
    "        \"\"\"\n",
    "        self.token = github_token or os.getenv('GITHUB_TOKEN')\n",
    "        self.repo_name = repo_name\n",
    "        self.is_available = bool(self.token)\n",
    "        self.github = None\n",
    "        \n",
    "        if self.is_available:\n",
    "            try:\n",
    "                from github import Github\n",
    "                self.github = Github(self.token)\n",
    "                print(\"✓ تم الاتصال بـ GitHub بنجاح\")\n",
    "            except Exception as e:\n",
    "                print(f\"⚠ فشل الاتصال بـ GitHub: {e}\")\n",
    "                self.is_available = False\n",
    "        else:\n",
    "            print(\"⚠ رمز GitHub غير متاح (يمكنك إضافته لاحقاً)\")\n",
    "    \n",
    "    def set_token(self, token: str):\n",
    "        \"\"\"تعيين رمز GitHub\"\"\"\n",
    "        try:\n",
    "            from github import Github\n",
    "            self.token = token\n",
    "            self.github = Github(token)\n",
    "            self.is_available = True\n",
    "            print(\"✓ تم تعيين رمز GitHub بنجاح\")\n",
    "        except Exception as e:\n",
    "            print(f\"✗ فشل تعيين رمز GitHub: {e}\")\n",
    "            self.is_available = False\n",
    "    \n",
    "    def upload_video(self, video_path: str, title: str, scenario: str) -> bool:\n",
    "        \"\"\"\n",
    "        تحميل الفيديو على GitHub\n",
    "        \n",
    "        Args:\n",
    "            video_path: مسار الفيديو المحلي\n",
    "            title: عنوان الفيديو\n",
    "            scenario: سيناريو الفيديو\n",
    "            \n",
    "        Returns:\n",
    "            True إذا نجحت عملية التحميل\n",
    "        \"\"\"\n",
    "        if not self.is_available:\n",
    "            print(\"⚠ GitHub غير متاح حالياً\")\n",
    "            return False\n",
    "        \n",
    "        try:\n",
    "            user = self.github.get_user()\n",
    "            \n",
    "            # محاولة الحصول على المستودع أو إنشاؤه\n",
    "            try:\n",
    "                repo = user.get_repo(self.repo_name)\n",
    "                print(f\"✓ المستودع موجود بالفعل\")\n",
    "            except:\n",
    "                print(f\"📁 إنشاء مستودع جديد: {self.repo_name}\")\n",
    "                repo = user.create_repo(\n",
    "                    self.repo_name,\n",
    "                    description=\"YouTube Shorts Generator - أداة لإنشاء فيديوهات قصيرة\",\n",
    "                    private=False,\n",
    "                    auto_init=True\n",
    "                )\n",
    "            \n",
    "            # تحميل الفيديو\n",
    "            with open(video_path, 'rb') as f:\n",
    "                video_content = f.read()\n",
    "            \n",
    "            timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n",
    "            file_path = f\"videos/{title[:30].replace('/', '_')}_{timestamp}.mp4\"\n",
    "            \n",
    "            try:\n",
    "                repo.create_file(\n",
    "                    file_path,\n",
    "                    f\"Add video: {title}\",\n",
    "                    video_content\n",
    "                )\n",
    "                print(f\"✓ تم تحميل الفيديو: {file_path}\")\n",
    "            except Exception as e:\n",
    "                print(f\"⚠ تحذير: قد يكون الملف موجوداً بالفعل: {e}\")\n",
    "            \n",
    "            # حفظ البيانات الوصفية\n",
    "            metadata = {\n",
    "                \"title\": title,\n",
    "                \"scenario\": scenario[:500],\n",
    "                \"timestamp\": timestamp,\n",
    "                \"video_file\": file_path\n",
    "            }\n",
    "            \n",
    "            metadata_path = f\"metadata/{title[:30].replace('/', '_')}_{timestamp}.json\"\n",
    "            try:\n",
    "                repo.create_file(\n",
    "                    metadata_path,\n",
    "                    f\"Add metadata for: {title}\",\n",
    "                    json.dumps(metadata, ensure_ascii=False, indent=2)\n",
    "                )\n",
    "                print(f\"✓ تم حفظ البيانات الوصفية\")\n",
    "            except:\n",
    "                print(f\"⚠ فشل حفظ البيانات الوصفية\")\n",
    "            \n",
    "            return True\n",
    "            \n",
    "        except Exception as e:\n",
    "            print(f\"✗ فشل تحميل الفيديو: {e}\")\n",
    "            return False\n",
    "\n",
    "print(\"✓ تم إنشاء فئة GithubManager\")"
   ]
