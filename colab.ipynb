    "                    gr.Markdown(\"اختر ألوان الخلفية (RGB)\")\n",
    "                    with gr.Row():\n",
    "                        color_r = gr.Slider(0, 255, value=20, label=\"🔴 أحمر (R)\", step=5)\n",
