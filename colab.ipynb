    "#@title 🎥 فئة إنشاء الفيديو\n",
    "\n",
    "class VideoGenerator:\n",
    "    \"\"\"محرك إنشاء الفيديو\"\"\"\n",
    "    \n",
    "    VIDEO_DIMENSIONS = (1080, 1920)  # عمودي كـ YouTube Shorts (width, height)\n",
    "    VIDEO_FPS = 30\n",
    "    VIDEO_DURATION = 60  # ثانية\n",
    "    \n",
    "    def __init__(self):\n",
    "        \"\"\"تهيئة محرك الفيديو\"\"\"\n",
    "        try:\n",
    "            from moviepy.editor import (\n",
    "                TextClip, ColorClip, CompositeVideoClip,\n",
    "                AudioFileClip, concatenate_videoclips, ImageClip\n",
    "            )\n",
    "            self.TextClip = TextClip\n",
    "            self.ColorClip = ColorClip\n",
    "            self.CompositeVideoClip = CompositeVideoClip\n",
    "            self.AudioFileClip = AudioFileClip\n",
    "            self.concatenate_videoclips = concatenate_videoclips\n",
    "            self.ImageClip = ImageClip\n",
    "            print(\"✓ تم تهيئة محرك الفيديو بنجاح\")\n",
    "        except Exception as e:\n",
    "            print(f\"✗ فشل تهيئة محرك الفيديو: {e}\")\n",
    "            raise\n",
    "    \n",
    "    def create_video(\n",
    "        self,\n",
    "        title: str,\n",
    "        scenario: str,\n",
    "        audio_path: str,\n",
    "        output_path: str,\n",
    "        background_color: Tuple[int, int, int] = (20, 25, 50)\n",
    "    ) -> bool:\n",
    "        \"\"\"\n",
    "        إنشاء فيديو من السيناريو والصوت\n",
    "        \n",
    "        Args:\n",
    "            title: عنوان الفيديو\n",
    "            scenario: السيناريو\n",
    "            audio_path: مسار الملف الصوتي\n",
    "            output_path: مسار حفظ الفيديو\n",
    "            background_color: لون الخلفية RGB\n",
    "            \n",
    "        Returns:\n",
    "            True إذا نجحت العملية\n",
    "        \"\"\"\n",
    "        try:\n",
    "            print(\"🎬 بدء إنشاء الفيديو...\")\n",
    "            \n",
    "            # إنشاء فيديو خلفية ملونة\n",
    "            background = self.ColorClip(\n",
    "                size=self.VIDEO_DIMENSIONS,\n",
    "                color=background_color,\n",
    "                duration=self.VIDEO_DURATION\n",
    "            )\n",
    "            \n",
    "            # إضافة العنوان\n",
    "            title_text = self.TextClip(\n",
    "                title,\n",
    "                fontsize=80,\n",
    "                color='white',\n",
    "                method='caption',\n",
    "                size=(self.VIDEO_DIMENSIONS[0]-40, None),\n",
    "                duration=10\n",
    "            ).set_position(('center', 0.25), relative=True)\n",
    "            \n",
    "            # إضافة السيناريو\n",
    "            scenario_text = scenario[:250] if len(scenario) > 250 else scenario\n",
    "            scenario_clip = self.TextClip(\n",
    "                scenario_text,\n",
    "                fontsize=40,\n",
    "                color='#FFD700',\n",
    "                method='caption',\n",
    "                size=(self.VIDEO_DIMENSIONS[0]-40, None),\n",
    "                duration=self.VIDEO_DURATION\n",
    "            ).set_position(('center', 0.6), relative=True)\n",
    "            \n",
    "            # دمج الطبقات\n",
    "            video = self.CompositeVideoClip([\n",
    "                background,\n",
    "                title_text,\n",
    "                scenario_clip\n",
    "            ])\n",
    "            \n",
    "            # إضافة الصوت إذا كان متاحاً\n",
    "            if os.path.exists(audio_path) and os.path.getsize(audio_path) > 0:\n",
    "                try:\n",
    "                    audio = self.AudioFileClip(audio_path)\n",
    "                    # قص الصوت إذا كان أطول من الفيديو\n",
    "                    if audio.duration > self.VIDEO_DURATION:\n",
    "                        audio = audio.subclipped(0, self.VIDEO_DURATION)\n",
    "                    video = video.set_audio(audio)\n",
    "                    print(\"✓ تم إضافة الصوت\")\n",
    "                except Exception as e:\n",
    "                    print(f\"⚠ فشل إضافة الصوت: {e}\")\n",
    "            \n",
    "            # حفظ الفيديو\n",
    "            print(f\"📹 حفظ الفيديو إلى {output_path}...\")\n",
    "            video.write_videofile(\n",
    "                output_path,\n",
    "                fps=self.VIDEO_FPS,\n",
    "                codec='libx264',\n",
    "                audio_codec='aac',\n",
    "                verbose=False,\n",
    "                logger=None\n",
    "            )\n",
    "            \n",
    "            print(f\"✓ تم إنشاء الفيديو بنجاح: {output_path}\")\n",
    "            return True\n",
    "            \n",
    "        except Exception as e:\n",
    "            print(f\"✗ فشل إنشاء الفيديو: {e}\")\n",
    "            print(traceback.format_exc())\n",
    "            return False\n",
    "\n",
    "print(\"✓ تم إنشاء فئة VideoGenerator\")"
   ]
  },
