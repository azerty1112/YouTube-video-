    "#@title 🎬 فئة المولد الرئيسي\n",
    "\n",
    "class YouTubeShortsGenerator:\n",
    "    \"\"\"الفئة الرئيسية لإدارة توليد YouTube Shorts\"\"\"\n",
    "    \n",
    "    def __init__(self, github_token: str = None):\n",
    "        \"\"\"\n",
    "        تهيئة المولد الرئيسي\n",
    "        \n",
    "        Args:\n",
    "            github_token: رمز GitHub\n",
    "        \"\"\"\n",
    "        print(\"🚀 تهيئة مولد YouTube Shorts...\")\n",
    "        \n",
    "        # تهيئة المكونات\n",
    "        self.scenario_generator = OllamaScenarioGenerator()\n",
    "        self.tts_engine = TextToSpeechEngine()\n",
    "        self.video_generator = VideoGenerator()\n",
    "        self.github_manager = GithubManager(github_token)\n",
    "        \n",
    "        # مجلد مؤقت\n",
    "        self.temp_dir = tempfile.mkdtemp(prefix='youtube_shorts_')\n",
    "        print(f\"📁 المجلد المؤقت: {self.temp_dir}\")\n",
    "    \n",
    "    def generate_short(\n",
    "        self,\n",
    "        title: str,\n",
    "        upload_to_github: bool = False,\n",
    "        background_color: Tuple[int, int, int] = (20, 25, 50)\n",
    "    ) -> Tuple[bool, str, Dict[str, Any]]:\n",
    "        \"\"\"\n",
    "        إنشاء فيديو YouTube Short كامل\n",
    "        \n",
    "        Args:\n",
    "            title: عنوان الفيديو\n",
    "            upload_to_github: هل يتم التحميل إلى GitHub\n",
    "            background_color: لون الخلفية\n",
    "            \n",
    "        Returns:\n",
    "            tuple: (النجاح، مسار الفيديو، البيانات الوصفية)\n",
    "        \"\"\"\n",
    "        try:\n",
    "            print(f\"\\n🎯 بدء إنشاء فيديو: {title}\")\n",
    "            \n",
    "            result_data = {\n",
    "                \"title\": title,\n",
    "                \"status\": \"processing\",\n",
    "                \"timestamp\": datetime.now().isoformat(),\n",
    "                \"steps\": []\n",
    "            }\n",
    "            \n",
    "            # 1. توليد السيناريو\n",
    "            print(\"📝 [خطوة 1] توليد السيناريو...\")\n",
    "            scenario = self.scenario_generator.generate_scenario(title)\n",
    "            if not scenario:\n",
    "                raise Exception(\"فشل توليد السيناريو\")\n",
    "            result_data[\"steps\"].append({\"step\": \"scenario_generation\", \"status\": \"success\"})\n",
    "            result_data[\"scenario\"] = scenario[:500]\n",
    "            print(f\"   ✓ تم توليد السيناريو ({len(scenario.split())} كلمة)\")\n",
    "            \n",
    "            # 2. تحويل النص إلى كلام\n",
    "            print(\"🔊 [خطوة 2] تحويل النص إلى كلام...\")\n",
    "            audio_path = os.path.join(self.temp_dir, \"audio.mp3\")\n",
    "            if self.tts_engine.text_to_speech(scenario, audio_path):\n",
    "                result_data[\"steps\"].append({\"step\": \"tts\", \"status\": \"success\"})\n",
    "                print(\"   ✓ تم تحويل النص إلى كلام\")\n",
    "            else:\n",
    "                print(\"   ⚠ سيتم إنشاء فيديو بدون صوت\")\n",
    "                audio_path = \"\"\n",
    "            \n",
    "            # 3. إنشاء الفيديو\n",
    "            print(\"🎬 [خطوة 3] إنشاء الفيديو...\")\n",
    "            video_path = os.path.join(self.temp_dir, f\"{title[:30].replace('/', '_')}.mp4\")\n",
    "            if not self.video_generator.create_video(\n",
    "                title, scenario, audio_path, video_path, background_color\n",
    "            ):\n",
    "                raise Exception(\"فشل إنشاء الفيديو\")\n",
    "            result_data[\"steps\"].append({\"step\": \"video_creation\", \"status\": \"success\"})\n",
    "            print(\"   ✓ تم إنشاء الفيديو بنجاح\")\n",
    "            \n",
    "            # 4. التحميل إلى GitHub\n",
    "            if upload_to_github and self.github_manager.is_available:\n",
    "                print(\"📤 [خطوة 4] تحميل الفيديو إلى GitHub...\")\n",
    "                if self.github_manager.upload_video(video_path, title, scenario):\n",
    "                    result_data[\"steps\"].append({\"step\": \"github_upload\", \"status\": \"success\"})\n",
    "                    print(\"   ✓ تم التحميل إلى GitHub\")\n",
    "            \n",
    "            result_data[\"status\"] = \"success\"\n",
    "            result_data[\"video_path\"] = video_path\n",
    "            result_data[\"file_size\"] = os.path.getsize(video_path) / (1024*1024)  # MB\n",
    "            \n",
    "            print(\"\\n✅ اكتمل إنشاء الفيديو بنجاح!\")\n",
    "            return True, video_path, result_data\n",
    "            \n",
    "        except Exception as e:\n",
    "            print(f\"\\n✗ خطأ: {e}\")\n",
    "            print(traceback.format_exc())\n",
    "            result_data[\"status\"] = \"failed\"\n",
    "            result_data[\"error\"] = str(e)\n",
    "            return False, \"\", result_data\n",
    "    \n",
    "    def cleanup(self):\n",
    "        \"\"\"تنظيف الملفات المؤقتة\"\"\"\n",
    "        try:\n",
    "            if os.path.exists(self.temp_dir):\n",
    "                shutil.rmtree(self.temp_dir)\n",
    "                print(\"✓ تم تنظيف الملفات المؤقتة\")\n",
    "        except Exception as e:\n",
    "            print(f\"⚠ فشل تنظيف الملفات: {e}\")\n",
    "\n",
    "print(\"✓ تم إنشاء فئة YouTubeShortsGenerator\")"
   ]
