    "#@title 📦 تثبيت المكتبات المطلوبة\n",
    "\n",
    "import subprocess\n",
    "import sys\n",
    "import logging\n",
    "from pathlib import Path\n",
    "\n",
    "# إعداد السجلات\n",
    "logging.basicConfig(\n",
    "    level=logging.INFO,\n",
    "    format='%(asctime)s - %(levelname)s - %(message)s'\n",
    ")\n",
    "logger = logging.getLogger(__name__)\n",
    "\n",
    "def install_package(package_name, version=None):\n",
    "    \"\"\"تثبيت مكتبة معينة\"\"\"\n",
    "    try:\n",
    "        if version:\n",
    "            package_spec = f\"{package_name}=={version}\"\n",
    "        else:\n",
    "            package_spec = package_name\n",
    "        \n",
    "        print(f\"📦 جاري تثبيت {package_name}...\")\n",
    "        subprocess.run(\n",
    "            [sys.executable, '-m', 'pip', 'install', package_spec, '-q'],\n",
    "            check=True,\n",
    "            timeout=300\n",
    "        )\n",
    "        print(f\"✓ تم تثبيت {package_name}\")\n",
    "        return True\n",
    "    except Exception as e:\n",
    "        print(f\"✗ فشل تثبيت {package_name}: {e}\")\n",
    "        return False\n",
    "\n",
    "# قائمة المكتبات المطلوبة\n",
    "packages = {\n",
    "    'gradio': '4.26.0',\n",
    "    'moviepy': '1.0.3',\n",
    "    'pillow': '10.1.0',\n",
    "    'numpy': '1.24.3',\n",
    "    'scipy': '1.11.4',\n",
    "    'pyttsx3': '2.90',\n",
    "    'requests': '2.31.0',\n",
    "    'PyGithub': '2.1.1',\n",
    "    'python-dotenv': '1.0.0',\n",
    "    'pydub': '0.25.1',\n",
    "}\n",
    "\n",
    "print(\"🔧 بدء تثبيت المكتبات المطلوبة...\\n\")\n",
    "\n",
    "for package, version in packages.items():\n",
    "    install_package(package, version)\n",
    "\n",
    "print(\"\\n✅ اكتمل تثبيت جميع المكتبات\")"
   ]
  },
