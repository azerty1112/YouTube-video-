    "#@title 🏗️ إنشاء الفئات الأساسية\n",
    "\n",
    "import os\n",
    "import json\n",
    "import traceback\n",
    "import shutil\n",
    "from datetime import datetime\n",
    "from typing import Tuple, Optional, Dict, Any\n",
    "import tempfile\n",
    "\n",
    "class OllamaScenarioGenerator:\n",
    "    \"\"\"توليد سيناريو الفيديو باستخدام Ollama Qwen\"\"\"\n",
    "    \n",
    "    def __init__(self, model_name: str = \"qwen\"):\n",
    "        \"\"\"\n",
    "        تهيئة مولد السيناريو\n",
    "        \n",
    "        Args:\n",
    "            model_name: اسم نموذج Ollama\n",
    "        \"\"\"\n",
    "        self.model_name = model_name\n",
    "        self.base_url = os.getenv('OLLAMA_URL', 'http://localhost:11434')\n",
    "        self.is_available = self._check_ollama()\n",
    "    \n",
    "    def _check_ollama(self) -> bool:\n",
    "        \"\"\"التحقق من توفر Ollama\"\"\"\n",
    "        try:\n",
    "            import requests\n",
    "            response = requests.get(f'{self.base_url}/api/tags', timeout=5)\n",
    "            is_available = response.status_code == 200\n",
    "            if is_available:\n",
    "                print(f\"✓ Ollama متاح على {self.base_url}\")\n",
    "            return is_available\n",
    "        except:\n",
    "            print(f\"⚠ لا يمكن الاتصال بـ Ollama (متوقع في Colab)\")\n",
    "            return False\n",
    "    \n",
    "    def generate_scenario(self, title: str, max_words: int = 300) -> Optional[str]:\n",
    "        \"\"\"\n",
    "        توليد سيناريو الفيديو\n",
    "        \n",
    "        Args:\n",
    "            title: عنوان الفيديو\n",
    "            max_words: الحد الأقصى لكلمات السيناريو\n",
    "            \n",
    "        Returns:\n",
    "            السيناريو المولد أو سيناريو افتراضي\n",
    "        \"\"\"\n",
    "        if not self.is_available:\n",
    "            print(\"⚠ Ollama غير متاح، استخدام سيناريو افتراضي\")\n",
    "            return self._generate_default_scenario(title)\n",
    "        \n",
    "        try:\n",
    "            import requests\n",
    "            \n",
    "            prompt = f\"\"\"\n",
    "أنت كاتب محتوى إبداعي متخصص في إنشاء فيديوهات YouTube Shorts جذابة.\n",
    "اكتب سيناريو قصير وجذاب لفيديو قصير بناءً على العنوان التالي:\n",
    "العنوان: {title}\n",
    "\n",
    "المتطلبات:\n",
    "- السيناريو يجب أن يكون درامياً وجذاباً\n",
    "- مناسب لفيديو قصير (15-60 ثانية)\n",
    "- يحتوي على خطوات واضحة\n",
    "- مكتوب باللغة العربية\n",
    "- لا يتجاوز {max_words} كلمة\n",
    "\n",
    "الرجاء كتابة السيناريو فقط بدون مقدمة أو تعليقات إضافية:\n",
    "\"\"\"\n",
    "            \n",
    "            response = requests.post(\n",
    "                f'{self.base_url}/api/generate',\n",
    "                json={\n",
    "                    'model': self.model_name,\n",
    "                    'prompt': prompt,\n",
    "                    'stream': False,\n",
    "                    'temperature': 0.7,\n",
    "                },\n",
    "                timeout=60\n",
    "            )\n",
    "            \n",
    "            if response.status_code == 200:\n",
    "                scenario = response.json().get('response', '').strip()\n",
    "                if scenario:\n",
    "                    print(f\"✓ تم توليد السيناريو بنجاح ({len(scenario.split())} كلمة)\")\n",
    "                    return scenario\n",
    "            \n",
    "            return self._generate_default_scenario(title)\n",
    "            \n",
    "        except Exception as e:\n",
    "            print(f\"⚠ خطأ في توليد السيناريو: {e}\")\n",
    "            return self._generate_default_scenario(title)\n",
    "    \n",
    "    def _generate_default_scenario(self, title: str) -> str:\n",
    "        \"\"\"توليد سيناريو افتراضي كبديل\"\"\"\n",
    "        return f\"\"\"\n",
    "🎬 سيناريو: {title}\n",
    "\n",
    "مشهد 1 (0-10 ثوان):\n",
    "- النص: مرحباً! اليوم سأشرح لكم: {title}\n",
    "- الوصف: لون متدرج جميل مع نص عريض\n",
    "\n",
    "مشهد 2 (10-30 ثانية):\n",
    "- النص: تابعوا معي الخطوات المهمة والحاسمة\n",
    "- الوصف: نص وتأثيرات بصرية جذابة\n",
    "\n",
    "مشهد 3 (30-50 ثانية):\n",
    "- النص: هذه كانت أهم المعلومات والنقاط الرئيسية\n",
    "- الوصف: شاشة تلخيصية\n",
    "\n",
    "مشهد 4 (50-60 ثانية):\n",
    "- النص: شكراً لمتابعتكم! لا تنسوا الاشتراك والإعجاب 👍\n",
    "- الوصف: دعوة للعمل مع موسيقى خاتمة\n",
    "\"\"\"\n",
    "\n",
    "print(\"✓ تم إنشاء فئة OllamaScenarioGenerator\")"
   ]
